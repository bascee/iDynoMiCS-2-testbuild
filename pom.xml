<!-- pom.xml -->
<project>
    <modelVersion>4.0.0</modelVersion>
    <groupId>com.idynomics</groupId>
    <artifactId>iDynoMiCS-2</artifactId>
    <version>2.0</version>
    <packaging>jar</packaging>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.8.1</version>
                <configuration>
                    <source>17</source>
                    <target>17</target>
                </configuration>
            </plugin>
            
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.2.0</version>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>idynomics.Idynomics</mainClass>
                            <addClasspath>true</addClasspath>
                            <classpathPrefix>lib/</classpathPrefix>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>3.1.2</version>
                <executions>
                    <execution>
                        <id>copy-dependencies</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-dependencies</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/lib</outputDirectory>
                            <includeScope>runtime</includeScope>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>3.2.0</version>
                <executions>
                    <execution>
                        <id>copy-resources</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/final-artifact</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>colourPalettes</directory>
                                    <targetPath>colourPalettes</targetPath>
                                </resource>
                                <resource>
                                    <directory>config</directory>
                                    <targetPath>config</targetPath>
                                </resource>
                                <resource>
                                    <directory>protocol</directory>
                                    <targetPath>protocol</targetPath>
                                </resource>
                                <resource>
                                    <directory>.</directory>
                                    <includes>
                                        <include>*.md</include>
                                        <include>config.*</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <dependencies>
        <!-- Local JAR dependencies from src/lib -->
        <dependency>
            <groupId>exificient</groupId>
            <artifactId>exificient-core</artifactId>
            <version>0.9.3</version>
            <scope>system</scope>
            <systemPath>${project.basedir}/src/lib/exificient-core.jar</systemPath>
        </dependency>
        <!-- Repeat for other JAR files in src/lib -->
        <!-- Example for JOGL: -->
        <dependency>
            <groupId>jogl</groupId>
            <artifactId>jogl-all</artifactId>
            <version>2.3.2</version>
            <scope>system</scope>
            <systemPath>${project.basedir}/src/lib/jogl/jogl-all.jar</systemPath>
        </dependency>
    </dependencies>
</project>
